# Client-side public configuration (bundled into browser JavaScript)
# These are NOT secret - they're visible in the browser
VITE_API_URL=http://localhost:3000
VITE_SOCKET_URL=http://localhost:3001
VITE_SERVER_IP=localhost
VITE_SERVER_PORT=3000
VITE_SOCKET_PORT=3001

# Server-side secrets (CHANGE THESE IN PRODUCTION!)
JWT_SECRET=your_jwt_secret_key_here
POSTGRES_USER=tictactoe
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_DB=tictactoe
PG_PORT=5432
